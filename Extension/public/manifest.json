{
  "manifest_version": 3,
  "name": "YTweak",
  "version": "1.0.1",
  "description": "Lorem ipsum dolor sit amet...",
  "default_locale": "en",
  "action": {
    "default_popup": "index.html"
  },
  "permissions": ["storage"],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["*://*.youtube.com/*"],
      "js": ["content.js"],
      "css": ["assets/features.css"],
      "run_at": "document_start"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["assets/*.css", "assets/*.js"],
      "matches": ["<all_urls>"]
    }
  ]
}
